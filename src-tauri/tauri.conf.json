{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "wo",
    "version": "0.1.0",
    "identifier": "com.idutsu",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "を研究所",
                "maximized": true,

                "resizable": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["../src/assets/icons/favicon-32x32.png", "../src/assets/icons/favicon.ico"]
    }
}
